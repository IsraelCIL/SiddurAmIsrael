{
  "id": "anenu_shliach_tzibur",
  "sections": [
    {
      "text": [
        "עֲנֵֽנוּ יְהֹוָה עֲנֵֽנוּ",
        "בְּיוֹם צוֹם תַּעֲנִיתֵֽנוּ",
        "כִּי בְצָרָה גְדוֹלָה אֲנָֽחְנוּ",
        "אַל תֵּֽפֶן אֶל רִשְׁעֵֽנוּ",
        "וְאַל תַּסְתֵּר פָּנֶֽיךָ מִמֶּֽנּוּ",
        "וְאַל תִּתְעַלַּם מִתְּחִנָּתֵֽנוּ",
        "הֱיֵה נָא קָרוֹב לְשַׁוְעָתֵֽנוּ",
        "יְהִי נָא חַסְדְּךָ לְנַחֲמֵֽנוּ",
        "טֶֽרֶם נִקְרָא אֵלֶֽיךָ עֲנֵֽנוּ",
        "כַּדָּבָר שֶׁנֶּאֱמַר",
        "וְהָיָ֥ה טֶֽרֶם יִקְרָ֖אוּ וַאֲנִ֣י אֶעֱנֶ֑ה",
        "ע֛וֹד הֵ֥ם מְדַבְּרִ֖ים וַאֲנִ֥י אֶשְׁמָֽע",
        "כִּי אַתָּה יְהֹוָה הָעוֹנֶה בְּעֵת צָרָה",
        "פּוֹדֶה וּמַצִּיל בְּכָל עֵת צָרָה וְצוּקָה:",
        "בָּרוּךְ אַתָּה יְהֹוָה הָעוֹנֶה בְּעֵת צָרָה:"
      ],
