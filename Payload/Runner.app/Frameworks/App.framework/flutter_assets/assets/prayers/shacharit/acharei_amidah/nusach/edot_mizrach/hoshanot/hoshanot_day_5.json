{
  "id": "hoshanot_day_5",
  "sections": [
    {
      "text": [
        "אֶרְחַץ בְּנִקָּיוֹן כַּפָּי וַאֲסֹבְבָה אֶת־מִזְבַּחֲךָ יְהֹוָֽה:",
        "לַשְׁמִעַ בְּקוֹל תּוֹדָה וּלְסַפֵּר כָּל־נִפְלְאוֹתֶֽיךָ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעֲנָא, הוֹשַׁעֲנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אֱלֹהֵינוּ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הפיוט להלן נאמר כל בכל יום ולקוח מסידור רס\"ג:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אַדִּיר אַדִּירִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַמְּיַחֵד לִכְבוֹדוֹ שְׁמוֹת חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַקּוֹנֶה בְּעוֹלָמוֹ קִנְיָנִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹצֵר בִּבְרִיּוֹתָיו גִּבּוֹרִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר אָב כָּרַת בְּרִית בִּבְתָרִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְהֵשִׁיב רְכוּשׁ לִמְלָכִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְחָנָן עַל הֲפִיכַת עָרִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר הַנֶּעְקָד בְּהַר מֹר שְׁעָרִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יָרַשׁ מֵהוֹרוֹ בְּרָכוֹת חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְהִשְׁלִים נֶפֶשׁ נְקוּבָה בְּשֵׁמוֹת חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר תָּם נַעֲשׂוּ לוֹ נִסִּים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וַיַּצֵּג מִבָּנָיו אַחִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כָּפְרוֹ שָׁת לְנָזִיר הַמַּחֲלִיף חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַמַּנְחִילֵנוּ דָּת סְפָרִים חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַמַּשְׁמִיעֵנוּ דִּבְּרוֹתָיו בְּקוֹלוֹת חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַכְּתוּבִים עַל הַלּוּחוֹת חֲמִשָּׁה חֲמִשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֱמוּנֶיךָ מִתְחַנְּנִים לַחֲבֹשׁ מַחֲצָם כְּמֵאָז חָבַשְׁתָּ, • יְהוָה אֱלֹהַי גָּדַלְתָּ מְּאֹד, הוֹד וְהָדָר לָבָשְׁתָּ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "נַהֲלֵנִי בְּחֻקּוֹתֶיךָ לְמַעַן שְׁלֹשֶׁת הוֹרַי, • יְהוָה נְחֵנִי בְצִדְקָתֶךָ לְמַעַן שׁוֹרְרָי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יְרִיבֶיךָ יֹאבְדוּ אֲשֶׁר בְּתִגְרָתָם סִגַּרְתָּנוּ, • יְהוָה הָאֵר פָּנֶיךָ אִתָּנוּ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יָהּ אֲשֶׁר אֵין לוֹ חֵקֶר שְׁלַח מְבַשֵּׂר צוּר עֵילוֹם, • יְהוָה עֹז לְעַמּוֹ יִתֵּן יְהוָה יְבָרֵךְ אֶת עַמּוֹ בַשָּׁלוֹם:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "צְפֵה גָּלוּתִי וְעָנְיִי אֵל נִדְרָשׁ לְכֹל שׁוֹאֵל, • יְהוָה צְבָאוֹת אֱלֹהֵי יִשְׂרָאֵל:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "חַנּוּן הַמְּרַחֵם מִי הִקְשָׁה אֵלָיו וַיִּשְׁלָם, • יְהוָה חַסְדֶּךָ לְעוֹלָם:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "קַבֵּל שַׁוְעִי מַלְכִּי וְגֹאֲלִי, • יְהוָה קְרָאתִיךָ חוּשָׁה לִּי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעְנָא. הוֹשַׁעְנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא. אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא יוֹצְרִי וּקְדֹשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שְׁעֵה לַחֲשִׁי וְרַחֲשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּמְחֵה וְהַעֲבֵר יוֹקְשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹם בְּיוֹם חֲמִישִׁי, הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא. אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא סְחֵה נָא מוֹקְשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְאַל תִּזְכָּר עָנְשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פְּנֵה אֵלַי דּוֹרְשִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹם בְּיוֹם חֲמִישִׁי, הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא. אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא, אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשָׁעְתָּ יְקוּשֵׁי מַלְבֵּן, • מֵרִמְסַת הַתֶּבֶן, • וּכְהִדּוּשׁ מַתְבֵּן, • דִּשַׁשְׁתָּ דּוֹשְׁשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סְפוֹרֵי עֶשֶׂר, • יָצְאוּ מִמַּאֲסֵר, • פְּצֵם נָא מֵחֹסֶר, • נְהַלֶּלְךָ בְּיוֹם חֲמִישִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשָׁעְתָּ יְשֻׁרוּן, • מִגּוֹי יְצִירוּן, • וּלְךָ יְשׁוֹרְרוּן, • אֵל מֵרִים רֹאשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שִׂפְתֵי רְנָנוֹת, • פָּצוּ לְךָ נְגִינוֹת, • בְּתוֹדָה וּבִתְחִנּוֹת, • נְהַלֶּלְךָ בְּיוֹם חֲמִישִׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "מָרוֹם שׁוֹכֵן עַד, נַעֲרָץ בִּקְדֻשָּׁה."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "תִּתְבָּרַךְ לָעַד, שֵׁם אֵל רָם וְנִשָּׂא."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "מְשׁוֹרְרִים וּמְהַלְלִים, בְּשִׁירָה חֲדָשָׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ פְּעָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעַ שְׂרִידֶיךָ, אֵל שׁוֹמֵר אֱמוּנִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "רַחוּם חֲסָדֶיךָ, חִישׁ נָא לְאֵיתָנִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּזְכֹר אֶת בְּרִיתְךָ, לָנוּ וְלִבְנֵי בָּנִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְהוֹשִׁיעָהּ לְהַרְגִּיעָהּ אֶבֶן הָרֹאשָׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ פְּעָמִים חֲמִשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַׁעְתָּ מֵאָז עֲדָתֶךָ,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "="
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
