{
  "id": "yehi_ratzon",
  "sections": [
    {
      "text": [
        "יְהִי רָצוֹן מִלְּפָנֶיךָ יְהֹוָה אֱלֹהֵינוּ וֵאלֹהֵי אֲבוֹתֵינוּ",
        "שֶׁיִּבָּנֶה בֵּית הַמִּקְדָּשׁ בִּמְהֵרָה בְיָמֵינוּ",
        "וְתֵן חֶלְקֵנוּ בְּתוֹרָתֶךָ:",
        "וְשָׁם נַעֲבָדְךָ בְּיִרְאָה",
        "כִּימֵי עוֹלָם וּכְשָׁנִים קַדְמוֹנִיּוֹת:",
        "וְעָרְבָה לַיהֹוָה מִנְחַת יְהוּדָה וִירוּשָׁלָיִם",
        "כִּימֵי עוֹלָם וּכְשָׁנִים קַדְמוֹנִיּוֹת:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
