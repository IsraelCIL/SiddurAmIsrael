  "sections": [
    {
      "text": "יְהֹוָה מֶֽלֶךְ יְהֹוָה מָלָךְ יְהֹוָה יִמְלֹךְ לְעֹלָם וָעֶד:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "יְהֹוָה מֶֽלֶךְ יְהֹוָה מָלָךְ יְהֹוָה יִמְלֹךְ לְעֹלָם וָעֶד:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "וְהָיָה יְהֹוָה לְמֶֽלֶךְ עַל כָּל הָאָֽרֶץ",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "בַּיּוֹם הַהוּא יִהְיֶה יְהֹוָה אֶחָד וּשְׁמוֹ אֶחָד:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "הוֹשִׁיעֵנוּ יְהֹוָה אֱלֹהֵינוּ וְקַבְּצֵנוּ מִן הַגּוֹיִם",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "לְהֹדוֹת לְשֵׁם קׇדְשֶׁךָ לְהִשְׁתַּבֵּחַ בִּתְהִלָּתֶֽךָ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "בָּרוּךְ יְהֹוָה אֱלֹהֵי יִשְׂרָאֵל מִן הָעוֹלָם וְעַד הָעוֹלָם",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "וְאָמַר כָּל הָעָם אָמֵן הַלְלוּיָהּ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "כֹּל הַנְּשָׁמָה תְּהַלֵּל יָהּ הַלְלוּיָהּ:",
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
