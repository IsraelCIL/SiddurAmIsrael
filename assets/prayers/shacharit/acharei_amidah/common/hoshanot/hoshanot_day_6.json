{
  "id": "hoshanot_day_6",
  "sections": [
    {
      "text": [
        "לְמַעַנְךָ אֱלֹהֵינוּ הוֹשַׁע נָא:",
        "לְמַעַנְךָ בּוֹרְאֵנוּ הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ גּוֹאֲלֵנוּ הוֹשַׁע נָא:",
        "לְמַעַנְךָ דּוֹרְשֵׁנוּ הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אָדֽוֹן הַמּוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בִּלְתְּךָֽ אַֽיִן לְהוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גִּבּֽוֹר וְרַֽב לְהוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "דַּלֹּתִֽי וְלִֽי יְהוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הָאֵֽל הַמּוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּמַצִּֽיל וּמוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "זֽוֹעֲקֶֽיךָ תּוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "חוֹכֶֽיךָ הוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "טְלָאֶֽיךָ תַּשְׂבִּֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יְבֽוּל לְהַשְׁפִּֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כׇּל־שִֽׂיחַ תַּדְשֵֽׁא וְתוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְגֵֽיא בַּל־תַּרְשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "מְגָדִֽים תַּמְתִּֽיק וְתוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "נְשִׂיאִֽים לְהַסִּֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שְׂעִירִֽים לְהָנִֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "עֲנָנִֽים מִלְּהַמְנִֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פוֹתֵֽחַ יָֽד וּמַשְׂבִּֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "צְמֵאֶֽיךָ תַּשְׂבִּֽיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "קֽוֹרְאֶֽיךָ תּושִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "רְחוּמֶֽיךָ תּוֹשִֽׁיעַ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שֽׁוֹחֲרֶֽיךָ הוֹשִֽׁיעַ. הושע נא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "תְּמִימֶֽיךָ תּוֹשִֽׁיעַ. הושע נא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ אֵלִֽים בְּלֽוּד עִמָּֽךְ. בְּצֵֽאתְךָֽ לְיֵֽשַׁע עַמָּֽךְ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ גּֽוֹי וֵֽאלֹהִֽים. דְּרוּשִֽׁים לְיֵֽשַׁע אֱלֹהִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ הֲמֽוֹן צִבְאֽוֹת. וְעִמָּֽם מַלְאֲכֵֽי צְבָאֽוֹת. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ זַכִּֽים מִבֵּֽית עֲבָדִֽים. חַנּֽוּן בְּיָדָֽם מַֽעֲבִידִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ טְבוּעִֽים בְּצֽוּל גְּזָרִֽים. יְקָֽרְךָֽ עִמָּֽם מַֽעֲבִירִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ כַּנָּֽה מְשׁוֹרֶֽרֶת וַיּֽוֹשַׁע. לְגוֹחָֽהּ מְצֻיֶּֽנֶת וַיִּוָּֽשַׁע. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ מַֽאֲמַֽר וְהֽוֹצֵאתִֽי אֶתְכֶֽם. נָקֽוּב וְהֽוּצֵאתִֽי אִתְּכֶֽם. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ סֽוֹבְבֵֽי מִזְבֵּֽחַ. עֽוֹמְסֵֽי עֲרָבָֽה לְהַקִּֽיף מִזְבֵּֽחַ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ פִּלְאֵֽי אָרֽוֹן כְּהֻפְשַֽׁע. צִעֵֽר פְּלֶֽשֶׁת בַּֽחֲרֽוֹן אַֽף וְנוֹשַֽׁע. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ קְהִלּֽוֹת בָּבֶֽלָה שִׁלַּֽחְתָּ. רַחֽוּם לְמַֽעֲנָֽם שֻׁלַּֽחְתָּ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ שְׁבֽוּת שִׁבְטֵֽי יַֽעֲקֹֽב. תָּשֽׁוּב וְתָשִֽׁיב שְׁבֽוּת אָֽהֳלֵֽי יַֽעֲקֹֽב. וְהוֹשִֽׁיעָה נָּֽא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ שֽׁוֹמְרֵֽי מִצְוֹֽת וְחוֹכֵֽי יְשׁוּעֽוֹת. אֵֽל לְמֽוֹשָׁעֽוֹת וְהוֹשִֽׁיעָה נָּֽא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעָה אֶת עַמֶּךָ וּבָרֵךְ אֶת נַחֲלָתֶךָ וּרְעֵם וְנַשְּׂאֵם עַד הָעוֹלָם:",
        "וְיִהְיוּ דְּבָרַי אֵלֶּה אֲשֶׁר הִתְחַנַּנְתִּי לִפְנֵי יְיָ קְרוֹבִים אֶל יְיָ אֱלֹהֵינוּ יוֹמָם וָלָיְלָה לַעֲשׂוֹת מִשְׁפַּט עַבְדּוֹ וּמִשְׁפַּט עַמּוֹ יִשְׂרָאֵל דְּבַר יוֹם בְּיוֹמוֹ:",
        "לְמַעַן דַּעַת כָּל עַמֵּי הָאָרֶץ כִּי יְיָ הוּא הָאֱלֹהִים אֵין עוֹד:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "קדיש שלם"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
