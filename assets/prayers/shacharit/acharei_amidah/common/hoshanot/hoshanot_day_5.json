{
  "id": "hoshanot_day_5",
  "sections": [
    {
      "text": [
        "לְמַעַנְךָ אֱלֹהֵינוּ הוֹשַׁע נָא:",
        "לְמַעַנְךָ בּוֹרְאֵנוּ הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ גּוֹאֲלֵנוּ הוֹשַׁע נָא:",
        "לְמַעַנְךָ דּוֹרְשֵׁנוּ הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֵֽל לְמֽוֹשָׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בְּאַרְבַּֽע שְׁבוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גָּשִֽׁים בְּשַׁוְעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "דּֽוֹפְקֵי עֶֽרֶך שׁוּעֽוֹת נ\"א שְעות."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹגֵֽי שַֽׁעֲשֻׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְחִֽידוֹתָֽם מִשְׁתַּעְשְׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "זֽוֹעֲקִֽים לְהַשְׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "חוֹכֵֽי יְשׁוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "טְפוּלִֽים בָּֽךְ שְׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יֽוֹדְעֵי בִֽין שָׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כּֽוֹרְעֶֽיךָ בְּשַׁוְעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְהָבִֽין שְׁמוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "מִפִּֽיךָ נִשְׁמָעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "נוֹתֵֽן תְּשׁוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סְפוּרֽוֹת מַשְׁמָעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "עֵדֽוּת מַשְׁמִיעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פּוֹעֵֽל יְשׁוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "צַדִּֽיק נֽוֹשָׁעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "קִרְיַֽת נ\"א קרב תְּשׁוּעֽוֹת."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "רֶֽגֶשׁ תְּשׁוּאֽות."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שָׁלֹֽש שָׁעֽוֹת. הושע נא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "תָּחִֽיש לִתְשׁוּעֽוֹת. הושע נא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ אֵלִֽים בְּלֽוּד עִמָּֽךְ. בְּצֵֽאתְךָֽ לְיֵֽשַׁע עַמָּֽךְ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ גּֽוֹי וֵֽאלֹהִֽים. דְּרוּשִֽׁים לְיֵֽשַׁע אֱלֹהִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ הֲמֽוֹן צִבְאֽוֹת. וְעִמָּֽם מַלְאֲכֵֽי צְבָאֽוֹת. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ זַכִּֽים מִבֵּֽית עֲבָדִֽים. חַנּֽוּן בְּיָדָֽם מַֽעֲבִידִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ טְבוּעִֽים בְּצֽוּל גְּזָרִֽים. יְקָֽרְךָֽ עִמָּֽם מַֽעֲבִירִֽים. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ כַּנָּֽה מְשׁוֹרֶֽרֶת וַיּֽוֹשַׁע. לְגוֹחָֽהּ מְצֻיֶּֽנֶת וַיִּוָּֽשַׁע. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ מַֽאֲמַֽר וְהֽוֹצֵאתִֽי אֶתְכֶֽם. נָקֽוּב וְהֽוּצֵאתִֽי אִתְּכֶֽם. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ סֽוֹבְבֵֽי מִזְבֵּֽחַ. עֽוֹמְסֵֽי עֲרָבָֽה לְהַקִּֽיף מִזְבֵּֽחַ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ פִּלְאֵֽי אָרֽוֹן כְּהֻפְשַֽׁע. צִעֵֽר פְּלֶֽשֶׁת בַּֽחֲרֽוֹן אַֽף וְנוֹשַֽׁע. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ קְהִלּֽוֹת בָּבֶֽלָה שִׁלַּֽחְתָּ. רַחֽוּם לְמַֽעֲנָֽם שֻׁלַּֽחְתָּ. כֵּן הוֹשַׁע נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ שְׁבֽוּת שִׁבְטֵֽי יַֽעֲקֹֽב. תָּשֽׁוּב וְתָשִֽׁיב שְׁבֽוּת אָֽהֳלֵֽי יַֽעֲקֹֽב. וְהוֹשִֽׁיעָה נָּֽא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַֽׁעְתָּ שֽׁוֹמְרֵֽי מִצְוֹֽת וְחוֹכֵֽי יְשׁוּעֽוֹת. אֵֽל לְמֽוֹשָׁעֽוֹת וְהוֹשִֽׁיעָה נָּֽא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעָה אֶת עַמֶּךָ וּבָרֵךְ אֶת נַחֲלָתֶךָ וּרְעֵם וְנַשְּׂאֵם עַד הָעוֹלָם:",
        "וְיִהְיוּ דְּבָרַי אֵלֶּה אֲשֶׁר הִתְחַנַּנְתִּי לִפְנֵי יְיָ קְרוֹבִים אֶל יְיָ אֱלֹהֵינוּ יוֹמָם וָלָיְלָה לַעֲשׂוֹת מִשְׁפַּט עַבְדּוֹ וּמִשְׁפַּט עַמּוֹ יִשְׂרָאֵל דְּבַר יוֹם בְּיוֹמוֹ:",
        "לְמַעַן דַּעַת כָּל עַמֵּי הָאָרֶץ כִּי יְיָ הוּא הָאֱלֹהִים אֵין עוֹד:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "קדיש שלם"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
