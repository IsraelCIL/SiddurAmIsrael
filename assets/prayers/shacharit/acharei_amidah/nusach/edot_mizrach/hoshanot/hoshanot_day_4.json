{
  "id": "hoshanot_day_4",
  "sections": [
    {
      "text": [
        "אֶרְחַץ בְּנִקָּיוֹן כַּפָּי וַאֲסֹבְבָה אֶת־מִזְבַּחֲךָ יְהֹוָֽה:",
        "לַשְׁמִעַ בְּקוֹל תּוֹדָה וּלְסַפֵּר כָּל־נִפְלְאוֹתֶֽיךָ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעֲנָא, הוֹשַׁעֲנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אֱלֹהֵינוּ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הפיוט להלן נאמר כל בכל יום ולקוח מסידור רס\"ג:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אַדִּיר אַדִּירִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַבּוֹרֵא עוֹלָמוֹ בִּיסוֹדוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַנּוֹתֵן נוֹשְׂאֵי כִסְאוֹ חַיּוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַמַּצִּיב פִּנּוֹת אַרְבָּעָה וּתְקוּפוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכוֹר אָב הֵעִיר מִמִּזְרָח בְּאוֹר לְיָמִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "רָדַף וַיְחַלֵּק עַל מְלָכִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בִּשַּׂרְתּוֹ לָשׁוּב זַרְעוֹ לְדוֹרוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכוֹר בֶּן הֻגַּשׁ לַעֲקֵדָה עַל קְרָנוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְחָפַר בִּפְלֶשֶׁת בּוֹרוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וַיַּעְתֵּק לְחֶבְרוֹן קִרְיַת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכוֹר תָּם נֶעְזַר בְּאִמָּהוֹת אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "חִנֵּן לְהִנָּצֵל מִשְּׁפָטִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בִּתְפִלָּתוֹ כִּלְכַּלְתָּ בָּנָיו בִּדְבָרִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַמּוֹלִיכֵנוּ בַּמִּדְבָּר בִּדְגָלִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "צִוָּה לְמַלֹּאות בַּחֹשֶׁן טוּרִים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַמְּצַוֵּנוּ לְהַלְּלוֹ בֶּחָג בְּמִנִּים אַרְבָּעָה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעְנָא. הוֹשַׁעְנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֶל פִּתְחָךְ יָרֹון שֶׂה אוֹבֵד בַּהֲדוֹמְךָ, • יְהֹוָה אֲדוֹנֵנוּ מָה אַדִּיר שִׁמְךָ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בַּיַעַר בַּעֲרָבָה בְּקוֹל יָעֹז, • יְהֹוָה ברְצוֹנְךָ הֶעֱמַדְתָּ לְהַרְרִי עוֹז:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גַּמֵּא צָמֵא לְיִשְׁעֲךָ פּוֹעֵר פִּיו לְמַלְקוֹשׁוֹ, • יְהֹוָה גּוֹאֵל יִשְׂרָאֵל וּקְדוֹשׁוֹ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "דִּבֵּר וַיִּקְרָא אָרֶץ דְּלֵה אֲסִירֶיךָ מִמְּצָרִים, • יְהֹוָה דּוֹבֵר צֶדֶק וּמַגִּיד מֵישָׁרִים:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הָבֵא שְׁנַת שִׁלּוּמִים לַאֲשֶׁר בַּדֶּשֶׁן נִדְשַׁנּוּ, • יְהֹוָה הַט שְׁמֶךָ וְתֵרֵד גַּע בֶּהָרִים וְיֶעֱשָׁנוּ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְהָרֵק חֲנִית וּסְגֹר לִקְרַאת רוֹדְפֵי כְּמֵהִים, • יְהֹוָה וְאֵין עוֹד זוּלָתוֹ אֵין אֱלֹהִים:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "זֶרַע אָדָם וְזֶרַע בְּהֵמָה תּוֹשִׁיעַ וְחִישׁ לְגוֹלַת אֲרִיאֵל, • יְהֹוָה זְכָרָנוּ יְבָרֵךְ אֶת בֵּית יִשְׂרָאֵל:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעְנָא. הוֹשַׁעְנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא. אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא יֶעֱרַב לְךָ שׁוּעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "בְּלוּלָבִי בְּנַעְנְעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְקָרֵב נָא קֵץ יִשְׁעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹם בְּיוֹם רְבִיעִי. הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא סוֹב נָא לְהַרְגִּיעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְכוֹנֵן אָרְחִי וְרִבְעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פָּעֳלִי שְׁעֵה בְּהִשְׁתַּעְשְׁעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "נַהֵל לִנְוֵה מַרְגּוֹעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹם בְּיוֹם רְבִיעִי. הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוּ הוֹשִׁיעָה נָא. אֲנִי וָהוֹ הוֹשִׁיעָה נָא:",
        "כְּהוֹשָׁעְתָּ יַקִּיר • מִשֹּׁד מְקַרְקַר קִיר • וָתַךְ וָתַעֲקִיר • שׁוֹקֵק שִׁקּוּעִי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גַּם עַתָּה חָלֵץ • אָלוּץ מִמְּאַלֵּץ • וּמַדְוֵי לֵב תְּעַלֵּץ • נְהַלֶּלָךְ בְּיוֹם רְבִיעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשָׁעְתָּ שׂוֹרֵק • מִכַּף צָר שׁוֹרֵק • אֲשֶׁר שִׁנָּיו חוֹרֵק • לְקַצֵּץ אֶת גִּזְעִי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פֶּתַע פִּתְאוֹם • נָאַמְתָּ נָאוֹם • לְהַשְׁבִּיתוֹ מִלְּאוֹם • נְהַלֶּלָךְ בְּיוֹם רְבִיעִי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יִשְׁעֲךָ הַרְאֵה יָהּ, הָאֵל גְּדוֹל דֵּעָה."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "מַהֵר קֵץ פְּדוּת, לְאֹם נִוָּשֵׁעָה."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ פְּעָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גּוֹאֵל יִשְׂרָאֵל, הֱיֵה נָא מוֹשִׁיעָם."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּבְעִתּוֹת כָּאֵל, הֱיֵה נָא מַרְגּוֹעָם."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גַּלֵּה קֵץ יִשְׁעָם, וּלְךָ לִישׁוּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ פְּעָמִים אַרְבָּעָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַׁעְתָּ מֵאָז עֲדָתֶךָ,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "="
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
