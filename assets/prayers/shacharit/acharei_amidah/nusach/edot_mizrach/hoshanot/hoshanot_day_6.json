{
  "id": "hoshanot_day_6",
  "sections": [
    {
      "text": [
        "אֶרְחַץ בְּנִקָּיוֹן כַּפָּי וַאֲסֹבְבָה אֶת־מִזְבַּחֲךָ יְהֹוָֽה:",
        "לַשְׁמִעַ בְּקוֹל תּוֹדָה וּלְסַפֵּר כָּל־נִפְלְאוֹתֶֽיךָ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעֲנָא, הוֹשַׁעֲנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אֱלֹהֵינוּ."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הפיוט להלן נאמר כל בכל יום ולקוח מסידור רס\"ג:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַנְךָ אַדִּיר אַדִּירִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַבּוֹרֵא עוֹלָמוֹ בְּיָמִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַבּוֹנֶה שֵׁשׁ צְלָעוֹת לִצְדָדִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹצֵר שְׂרָפִים בִּכְנָפַיִם שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר אָב זָנַח תּוֹעֵבוֹת שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אַחֲרֵי זְקֻנָיו נוֹלְדוּ לוֹ בָּנִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "נָטַע אֶשֶׁל וּבֹרַךְ בְּקֵץ שָׁנִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר הַנֶּעֱקָד בִּמְקוֹם מַעַרְכוֹת שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "גּוֹנַנְתּוֹ וּמִלַּטְתּוֹ מִצָּרוֹת שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כָּרָה מִקְוָאוֹת לְדוֹרְשִׁי בָּם מַעֲלוֹת שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא זְכֹר תָּם הוֹלִיד מִן הַבְּכִירָה שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְצִוָּה קַחַת מִנְחָה מִמִּינִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְהִגְבִּיר אֲבִי שִׁשָּׁה, הַמְבֹרָכִים בְּשִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הַמְחַבֵּר לָאֵפוֹד שְׁמוֹת שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַמַּצִּיל נְפָשׁוֹת בְּעָרֵי מִקְלָט שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַמּוֹרִישֶׁנּוּ חָכְמַת סְדָרִים שִׁשָּׁה,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעֵנוּ בַּחֲגִיגַת יָמִים שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעְנָא, הוֹשַׁעְנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן אָב אָץ לָבֹא בְּיִחוּד הַשֵּׁם וּדְבַר הַמֶּלֶךְ הָיָה נָחוּץ, • בֹּא בְּרוּךְ יְהוָה לָמָּה תַעֲמֹד בַּחוּץ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן גָּעָה לִמְרִירוּת מַטְבֵּחַ וּבֻשַּׂר בְּאֶהְיֶה אֲשֶׁר אֶהְיֶה, • דְּבַר יְהוָה שָׁלוֹם יִהְיֶה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן הַבְּרִית אֲשֶׁר כָּרַת לְאִישׁ תָּם יוֹשֵׁב אֹהָלָיו, • והִנֵּה יְהוָה נִצַּב עָלָיו:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן זַךְ נִרְאֵיתָ לוֹ בַּשֵּׂר לַהֲמוֹנַי, • חִזְקוּ וְיַאֲמֵץ לְבַבְכֶם כָּל הַמְיַחֲלִים לַיהוָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן קוֹרְאֶיךָ בֶּעָשׂוֹר אֲנָשִׁים וְנָשִׁים וָטָף, • רְעֵבִים גַּם צְמֵאִים נַפְשָׁם בָּהֶם תִּתְעַטָּף:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "לְמַעַן שֵׁם קָדְשֶׁךָ שְׁאוֹן יָמִים תַּשְׁבִּיחַ, • תִּפְתַּח אֶרֶץ וְיִפְרוּ יֶשַׁע וּצְדָקָה תַצְמִיחַ:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשַׁעְנָא. הוֹשַׁעְנָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא הוֹשִׁיעָה נָא. אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא יַשֵּׁר מַעֲרָכִי, • וְהַיְשַׁר מַהֲלָכִי, • וְכוֹנְנָה אֶת דַּרְכִּי, • לָלֶכֶת אֶל הַר קָדְשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּקְרָא נָא דְּרוֹר, • לִרְווּיֵי מַמְרוֹר, • וְשִׂיחָם יֶעֱרַב כְּמוֹ מָר דְּרוֹר, • הַיּוֹם בְּיוֹם שִׁשִּׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעָה נָא:",
        "אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנָא סַגֵּל סְגֻלָּתֶךָ, • וְקַבֵּץ קְהִלָּתֶךָ, • לְהַר נַחֲלָתֶךָ, • מְקוֹם מִקְדָּשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "פְּזוּרִים תְּקַבֵּץ, • לִנְוֵה מַרְבֵּץ, • וְתַלְבִּישֵׁם תַּשְׁבֵּץ, • הַיּוֹם בְּיוֹם שִׁשִּׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הוֹשִׁיעָה נָא:",
        "אֲנָא הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא, אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשָׁעְתָּ יְלִידֵי אַהַב, • מְאוֹר הַלַּהַב, • וּמָחַצְתָּ רַהַב, • לְכַלּוֹת אֶת קָדְשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סָלוּל וּמַסְלוּל, • פִּתַּחְתָּ בְּמַצְלוּל, • לַעֲבֹר עַם כָּלוּל, • נְהַלֶּלָךְ בְּיוֹם שִׁשִּׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשָׁעְתָּ יְחִילֵי קוֹל תּוֹר, • מֵאֶרֶץ כַּפְתּוֹר, • וַתָשֶׂם מִסְתּוֹר, • עָלֵימוֹ קְדֹשִׁי:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סִגַּפְתָּ פּוּט, • בִּשְׁחִין נָפוּט, • לְחַלֵּץ עַם שָׁפוּט, • נְהַלֶּלָךְ בְּיוֹם שִׁשִּׁי,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כֵּן הוֹשַׁעְנָא:",
        "אֲנִי וָהוֹ הוֹשִׁיעָה נָא:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "שְׁעֵה עֶלְיוֹן לַחֲשִׁי, נַעֲרָץ בִּקְדֻשָּׁה."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַיּוֹם לְךָ בְּדוֹרְשִׁי, בְּשִׁירָה חֲדָשָׁה."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּבֹשׁ נָא אֶת כּוֹבְשִׁי, רְפָא מַכָּה אֲנוּשָׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ זֹאת הַפַּעַם שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "הַקְשֵׁב נָא קוֹל אֶבְיוֹן, בְּקָרְאוֹ מִן מְצָרִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "עַם הוֹמֶה בְּצִיּוֹן, בְּיַד עַמִּים אַכְזָרִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וְחִישׁ יֶשַׁע וּפִדְיוֹן, לְעַם בְּלֹא הוֹן נִמְכָּרִים."
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "וּשְׁבוּת גְּאֻלָּתָם, תְּמַהֵר תָּחִישָׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "סוֹבְבֵי תּוֹרָתְךָ זֹאת הַפַּעַם שִׁשָּׁה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "כְּהוֹשַׁעְתָּ מֵאָז עֲדָתֶךָ,"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "="
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
