{
  "id": "kedushah",
  "sections": [
    {
      "text": [
        "נְקַדֵּשׁ אֶת שִׁמְךָ בָּעוֹלָם",
        "כְּשֵׁם שֶׁמַּקְדִּישִׁים אוֹתוֹ בִּשְׁמֵי מָרוֹם",
        "כַּכָּתוּב עַל יַד נְבִיאֶֽךָ",
        "וְקָרָא זֶה אֶל זֶה וְאָמַר:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "קָדוֹשׁ קָדוֹשׁ קָדוֹשׁ יְהֹוָה צְבָאוֹת מְלֹא כָל הָאָֽרֶץ כְּבוֹדוֹ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "לְעֻמָּתָם בָּרוּךְ יֹאמֵֽרוּ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "בָּרוּךְ כְּבוֹד יְהֹוָה מִמְּקוֹמוֹ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "וּבְדִבְרֵי קָדְשְׁךָ כָּתוּב לֵאמֹר:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "יִמְלֹךְ יְהֹוָה לְעוֹלָם אֱלֹהַֽיִךְ צִיּוֹן לְדֹר וָדֹר הַלְלוּיָהּ:",
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
