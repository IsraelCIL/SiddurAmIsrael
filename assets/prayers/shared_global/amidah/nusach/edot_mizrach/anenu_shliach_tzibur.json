{
  "id": "anenu_shliach_tzibur",
  "sections": [
    {
      "text": [
        "עֲנֵֽנוּ אָבִֽינוּ עֲנֵֽנוּ",
        "בְּיוֹם צוֹם הַתַּֽעֲנִית הַזֶּה",
        "כִּי בְצָרָה גְדוֹלָה אֲנָֽחְנוּ",
        "אַל תֵּֽפֶן לְרִשְׁעֵֽנוּ",
        "וְאַל תִּתְעַלָּם מַלְכֵּֽנוּ מִבַּקָּשָׁתֵֽנוּ",
        "הֱיֵה נָא קָרוֹב לְשַׁוְעָתֵֽנוּ",
        "טֶֽרֶם נִקְרָא אֵלֶֽיךָ אַתָּה תַֽעֲנֶה",
        "נְדַבֵּר וְאַתָּה תִשְׁמַע",
        "כַּדָּבָר שֶׁנֶּאֱמַר",
        "וְהָיָ֥ה טֶֽרֶם יִקְרָ֖אוּ וַאֲנִ֣י אֶעֱנֶ֑ה",
        "ע֛וֹד הֵ֥ם מְדַבְּרִ֖ים וַאֲנִ֥י אֶשְׁמָֽע",
        "כִּי אַתָּה יְהֹוָה פּוֹדֶה וּמַצִּיל",
        "וְעוֹנֶה וּמְרַחֵם בְּכָל עֵת צָרָה וְצוּקָה:"
      ],
      "condition_flags": ["taanit"], "exclude_flags": []
    }
  ]
}
