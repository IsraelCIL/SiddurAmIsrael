{
  "id": "ein_kohanim_bracha",
  "sections": [
    {
      "text": [
        "אֱלֹהֵֽינוּ וֵאלֹהֵי אֲבוֹתֵֽינוּ",
        "בָּרְ֒כֵֽנוּ בַבְּ֒רָכָה הַמְּ֒שֻׁלֶּֽשֶׁת בַּתּוֹרָה הַכְּ֒תוּבָה עַל יְדֵי משֶׁה עַבְדֶּֽךָ,",
        "הָאֲמוּרָה מִפִּי אַהֲרֹן וּבָנָיו",
        "כֹּהֲנִים עַם קְדוֹשֶֽׁךָ כָּאָמוּר:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יְבָרֶכְ֒ךָ יְהֹוָה וְיִשְׁמְ֒רֶֽךָ:",
        "יָאֵר יְהֹוָה פָּנָיו אֵלֶֽיךָ וִיחֻנֶּֽךָּ:",
        "יִשָּׂא יְהֹוָה פָּנָיו אֵלֶֽיךָ וְיָשֵׂם לְךָ שָׁלוֹם:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}