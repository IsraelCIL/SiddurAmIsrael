{
  "id": "modim_derabanan",
  "sections": [
    {
      "text": [
        "מוֹדִים אֲנַֽחְנוּ לָךְ",
        "שָׁאַתָּה הוּא יְהֹוָה אֱלֹהֵֽינוּ וֵאלֹהֵי אֲבוֹתֵֽינוּ",
        "אֱלֹהֵי כָל בָּשָׂר יוֹצְרֵֽנוּ יוֹצֵר בְּרֵאשִׁית",
        "בְּרָכוֹת וְהוֹדָאוֹת לְשִׁמְךָ הַגָּדוֹל וְהַקָּדוֹשׁ",
        "עַל שֶׁהֶחֱיִיתָֽנוּ וְקִיַּמְתָּֽנוּ",
        "כֵּן תְּחַיֵּֽינוּ וּתְקַיְּמֵֽנוּ",
        "וְתֶאֱסוֹף גָּלֻיּוֹתֵֽינוּ לְחַצְרוֹת קָדְשֶֽׁךָ",
        "לִשְׁמוֹר חֻקֶּֽיךָ וְלַעֲשׂוֹת רְצוֹנֶֽךָ",
        "וּלְעָבְדְּךָ בְּלֵבָב שָׁלֵם",
        "עַל שֶׁאֲנַֽחְנוּ מוֹדִים לָךְ:",
        "בָּרוּךְ אֵל הַהוֹדָאוֹת:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
