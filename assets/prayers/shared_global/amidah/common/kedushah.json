{
  "id": "kedushah",
  "sections": [
    {
      "text": [
        "נַקְדִּישָׁךְ וְנַעֲרִיצָךְ",
        "כְּנֹֽעַם שִׂיחַ סוֹד שַׂרְפֵי קֹֽדֶשׁ",
        "הַמְּשַׁלְּשִׁים לְךָ קְדֻשָּׁה",
        "כַּכָּתוּב עַל יַד נְבִיאֶֽךָ",
        "וְקָרָא זֶה אֶל זֶה וְאָמַר:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "קָדוֹשׁ קָדוֹשׁ קָדוֹשׁ יְהֹוָה צְבָאוֹת מְלֹא כָל הָאָֽרֶץ כְּבוֹדוֹ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "לְעֻמָּתָם מְשַׁבְּחִים וְאוֹמְרִים:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "בָּרוּךְ כְּבוֹד יְהֹוָה מִמְּקוֹמוֹ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "וּבְדִבְרֵי קָדְשְׁךָ כָּתוּב לֵאמֹר:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "יִמְלֹךְ יְהֹוָה לְעוֹלָם אֱלֹהַֽיִךְ צִיּוֹן לְדֹר וָדֹר הַלְלוּיָהּ:",
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "אַתָּה קָדוֹשׁ וְשִׁמְךָ קָדוֹשׁ",
        "וּקְדוֹשִׁים בְּכָל יוֹם יְהַלְלֽוּךָ סֶּֽלָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": "בָּרוּךְ אַתָּה יְהֹוָה הָאֵל הַקָּדוֹשׁ:",
      "condition_flags": [],
      "exclude_flags": [
        "aseret_yemei_teshuva"
      ]
    },
    {
      "text": "בָּרוּךְ אַתָּה יְהֹוָה הַמֶּֽלֶךְ הַקָּדוֹשׁ:",
      "condition_flags": [
        "aseret_yemei_teshuva"
      ],
      "exclude_flags": []
    }
  ]
}
