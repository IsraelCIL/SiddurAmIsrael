{
  "id": "birkat_kohanim_bracha",
  "optional": true,
  "sections": [
    {
      "text": [
        "בָּרוּךְ אַתָּה יְהֹוָה אֱלֹהֵֽינוּ מֶֽלֶךְ הָעוֹלָם",
        "אֲשֶׁר קִדְּשָׁנוּ בִּקְדֻשָּׁתוֹ שֶׁל אַהֲרֹן",
        "וְצִוָּנוּ לְבָרֵךְ אֶת עַמּוֹ יִשְׂרָאֵל בְּאַהֲבָה:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    },
    {
      "text": [
        "יְבָרֶכְ֒ךָ יְהֹוָה וְיִשְׁמְ֒רֶֽךָ:",
        "יָאֵר יְהֹוָה פָּנָיו אֵלֶֽיךָ וִיחֻנֶּֽךָּ:",
        "יִשָּׂא יְהֹוָה פָּנָיו אֵלֶֽיךָ וְיָשֵׂם לְךָ שָׁלוֹם:"
      ],
      "condition_flags": [],
      "exclude_flags": []
    }
  ]
}
